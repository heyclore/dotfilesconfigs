USB_EXCLUDE_PRINTER=0

DEVICES_TO_ENABLE_ON_STARTUP="wifi"
DEVICES_TO_ENABLE_ON_AC="wifi"
DEVICES_TO_DISABLE_ON_BAT="bluetooth nfc wwan"
DEVICES_TO_DISABLE_ON_BAT_NOT_IN_USE="bluetooth nfc wwan"

