# --- Core TLP Settings ---
TLP_ENABLE=1
TLP_WARN_LEVEL=2
TLP_AUTO_SWITCH=1
TLP_PROFILE_AC=SAV
TLP_PROFILE_BAT=SAV

# --- Processor Settings (AMD P-State & EPP) ---
# Active mode is best for the Z1 Extreme to utilize EPP 'power'
CPU_DRIVER_OPMODE_ON_AC=active
CPU_DRIVER_OPMODE_ON_BAT=active

CPU_SCALING_GOVERNOR_ON_AC=powersave
CPU_SCALING_GOVERNOR_ON_BAT=powersave

# EPP 'power' is the most aggressive energy saving hint for Zen 4
CPU_ENERGY_PERF_POLICY_ON_AC=power
CPU_ENERGY_PERF_POLICY_ON_BAT=power

# Performance Limits (As per your request)
CPU_MIN_PERF_ON_AC=0
CPU_MAX_PERF_ON_AC=88
CPU_MIN_PERF_ON_BAT=0
CPU_MAX_PERF_ON_BAT=66

# Disable Boosts
CPU_BOOST_ON_AC=0
CPU_BOOST_ON_BAT=0
CPU_HWP_DYN_BOOST_ON_AC=0
CPU_HWP_DYN_BOOST_ON_BAT=0

# Watchdog uses CPU cycles; disabling saves a tiny amount of power
NMI_WATCHDOG=0

# --- Graphics & Display ---
# Force Radeon DPM to lowest clock speeds
RADEON_DPM_PERF_LEVEL_ON_AC=low
RADEON_DPM_PERF_LEVEL_ON_BAT=low

# AMDGPU ABM (Adaptive Backlight Management) - 4 is max saving
AMDGPU_ABM_LEVEL_ON_AC=4
AMDGPU_ABM_LEVEL_ON_BAT=4

# --- Platform & System ---
PLATFORM_PROFILE_ON_AC=low-power
PLATFORM_PROFILE_ON_BAT=low-power
MEM_SLEEP_ON_BAT=deep

# --- Disk & Storage ---
DISK_DEVICES="nvme0n1"
DISK_IOSCHED="mq-deadline"
DISK_SPINDOWN_TIMEOUT_ON_AC="0 0"
DISK_SPINDOWN_TIMEOUT_ON_BAT="0 0"

# Aggressive NVMe/SATA Power Management
SATA_LINKPWR_ON_AC="min_power"
SATA_LINKPWR_ON_BAT="min_power"
AHCI_RUNTIME_PM_ON_AC=auto
AHCI_RUNTIME_PM_ON_BAT=auto
AHCI_RUNTIME_PM_TIMEOUT=15

# --- Network & Connectivity ---
WIFI_PWR_ON_AC=on
WIFI_PWR_ON_BAT=on
WOL_DISABLE=Y

# --- Audio ---
SOUND_POWER_SAVE_ON_AC=1
SOUND_POWER_SAVE_ON_BAT=1
SOUND_POWER_SAVE_CONTROLLER=Y

# --- PCIe & USB (The Big Savers) ---
PCIE_ASPM_ON_AC=powersupersave
PCIE_ASPM_ON_BAT=powersupersave

# Enable Runtime PM for all PCIe devices including GPU
RUNTIME_PM_ON_AC=auto
RUNTIME_PM_ON_BAT=auto
RUNTIME_PM_DRIVER_DENYLIST=""

# Force USB Autosuspend
USB_AUTOSUSPEND=1
USB_EXCLUDE_AUDIO=0
USB_EXCLUDE_BTUSB=0
USB_EXCLUDE_PRINTER=0
USB_EXCLUDE_WWAN=0

# --- Radio Device Management ---
DEVICES_TO_ENABLE_ON_STARTUP="wifi"
DEVICES_TO_ENABLE_ON_AC="wifi"
DEVICES_TO_DISABLE_ON_BAT="bluetooth nfc wwan"
DEVICES_TO_DISABLE_ON_BAT_NOT_IN_USE="bluetooth nfc wwan"

# --- Hardware Specific Plugins (Disabled as requested) ---
NATACPI_ENABLE=0
TPACPI_ENABLE=0
TPSMAPI_ENABLE=0
