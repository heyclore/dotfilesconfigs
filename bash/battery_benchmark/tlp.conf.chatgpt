# Always use power-saver profile
TLP_PROFILE_AC=SAV
TLP_PROFILE_BAT=SAV

# CPU – maximum saving
CPU_SCALING_GOVERNOR_ON_AC=powersave
CPU_SCALING_GOVERNOR_ON_BAT=powersave
CPU_SCALING_GOVERNOR_ON_SAV=powersave

CPU_ENERGY_PERF_POLICY_ON_AC=power
CPU_ENERGY_PERF_POLICY_ON_BAT=power
CPU_ENERGY_PERF_POLICY_ON_SAV=power

CPU_BOOST_ON_AC=0
CPU_BOOST_ON_BAT=0
CPU_BOOST_ON_SAV=0

# Platform profile
PLATFORM_PROFILE_ON_AC=low-power
PLATFORM_PROFILE_ON_BAT=low-power
PLATFORM_PROFILE_ON_SAV=low-power

# AMD GPU – force lowest behavior
RADEON_DPM_PERF_LEVEL_ON_AC=low
RADEON_DPM_PERF_LEVEL_ON_BAT=low
RADEON_DPM_PERF_LEVEL_ON_SAV=low

AMDGPU_ABM_LEVEL_ON_AC=4
AMDGPU_ABM_LEVEL_ON_BAT=4
AMDGPU_ABM_LEVEL_ON_SAV=4

# PCIe + runtime PM
PCIE_ASPM_ON_AC=powersupersave
PCIE_ASPM_ON_BAT=powersupersave
PCIE_ASPM_ON_SAV=powersupersave

RUNTIME_PM_ON_AC=auto
RUNTIME_PM_ON_BAT=auto

# USB autosuspend aggressive
USB_AUTOSUSPEND=1
USB_EXCLUDE_AUDIO=0
USB_EXCLUDE_BTUSB=0
USB_EXCLUDE_PHONE=0
USB_EXCLUDE_PRINTER=0
USB_EXCLUDE_WWAN=0

# WiFi power save
WIFI_PWR_ON_AC=on
WIFI_PWR_ON_BAT=on

# Disable radios completely
DEVICES_TO_DISABLE_ON_STARTUP="bluetooth wwan"

# Sound power save
SOUND_POWER_SAVE_ON_AC=1
SOUND_POWER_SAVE_ON_BAT=1
SOUND_POWER_SAVE_CONTROLLER=Y

# Disk (mostly irrelevant if NVMe, but safe)
DISK_APM_LEVEL_ON_AC="255"
DISK_APM_LEVEL_ON_BAT="255"

# SATA/NVMe runtime PM
AHCI_RUNTIME_PM_ON_AC=auto
AHCI_RUNTIME_PM_ON_BAT=auto

# Kernel watchdog off
NMI_WATCHDOG=0
